NC='\033[0m'
H_BLUE='\033[1;34m'
H_GREEN='\033[1;32m'
H_YELLOW='\033[1;33m'
H_RED='\033[1;31m'
H_CYAN='\033[1;36m'

_info() {
  local fmt=$1
  shift
  printf "${H_BLUE}%-10s${NC} ${fmt}\n" "${TAG_INFO}" "$@"
}

_success() {
  local fmt=$1
  shift
  printf "${H_GREEN}%-10s${NC} ${fmt}\n" "${TAG_SUCCESS}" "$@"
}

_warn() {
  local fmt=$1
  shift
  printf "${H_YELLOW}%-10s${NC} ${fmt}\n" "${TAG_WARN}" "$@"
}

_error() {
  local fmt=$1
  shift
  printf "${H_RED}%-10s${NC} ${fmt}\n" "${TAG_ERROR}" "$@"
  exit 1
}

dry_run_action() {
  local action=$1
  _warn "${MSG[DRY_WOULD_RUN]}" "$action"
}

cleanup_on_exit() {
  if [[ -n "${SUDO_PID:-}" ]]; then
    kill "$SUDO_PID" 2>/dev/null || true
  fi
}

detect_package_manager() {
  if command -v paru >/dev/null 2>&1; then
    PKG_MNGR="paru"
  elif command -v yay >/dev/null 2>&1; then
    PKG_MNGR="yay"
  elif command -v pacman >/dev/null 2>&1; then
    PKG_MNGR="pacman"
  else
    _error "${MSG[NO_HELPER]}"
  fi
}

print_intro_and_confirm() {
  if [[ "$SKIP_CONFIRM" == true ]]; then
    return
  fi

  printf "\n${H_CYAN}%s${NC}\n" "${MSG[INTRO_HEADER]}"
  printf "%s\n" "${MSG[DESC_TITLE]}"
  printf "  %s\n" "${MSG[DESC_1]}"
  printf "  %s\n" "${MSG[DESC_2]}"
  printf "  %s\n" "${MSG[DESC_3]}"
  printf "  %s\n" "${MSG[DESC_4]}"
  printf "  %s\n" "${MSG[DESC_5]}"
  printf "  %s\n" "${MSG[DESC_6]}"
  printf "  %s\n" "${MSG[DESC_7]}"
  printf "  %s\n" "${MSG[DESC_8]}"

  if [[ "$CLEAN_ALL" == true ]]; then
    printf "  ${H_RED}%s${NC}\n" "${MSG[DESC_ALL_1]}"
    printf "  ${H_RED}%s${NC}\n" "${MSG[DESC_ALL_2]}"
  fi
  if [[ "$DRY_RUN" == true ]]; then
    printf "  ${H_YELLOW}%s${NC}\n" "${MSG[DESC_DRY]}"
  fi

  printf "\n${H_YELLOW}%s ${NC}" "${MSG[ASK_CONFIRM]}"
  read -r confirm || true
  case "$confirm" in
  [yY][eE][sS] | [yY] | "")
    ;;
  *)
    printf "%s\n" "${MSG[ABORT]}"
    exit 0
    ;;
  esac
}

start_sudo_keepalive() {
  if ! sudo -v; then
    _error "${MSG[SUDO_FAIL]}"
  fi

  while true; do
    sudo -n true
    sleep 60
  done 2>/dev/null &
  SUDO_PID=$!
  trap cleanup_on_exit EXIT
}

cleanup_orphans() {
  _info "${MSG[STEP_ORPHAN]}"
  local orphans
  orphans=$(pacman -Qtdq || true)

  if [[ -z "$orphans" ]]; then
    _success "${MSG[ORPHAN_NONE]}"
    return
  fi

  _warn "${MSG[ORPHAN_FOUND]}"
  mapfile -t orphan_arr <<<"$orphans"
  if [[ "$DRY_RUN" == true ]]; then
    dry_run_action "$PKG_MNGR -Rns <orphans> --noconfirm (${#orphan_arr[@]} packages)"
    _success "${MSG[DRY_STEP_DONE]}"
    return
  fi
  "$PKG_MNGR" -Rns "${orphan_arr[@]}" --noconfirm
  _success "${MSG[ORPHAN_CLEAN]}"
}

cleanup_package_cache() {
  if [[ "$CLEAN_ALL" == true ]]; then
    _info "${MSG[STEP_CACHE_ALL]}"
    if [[ "$DRY_RUN" == true ]]; then
      dry_run_action "$PKG_MNGR -Scc"
      _success "${MSG[DRY_STEP_DONE]}"
      return
    fi
    yes | "$PKG_MNGR" -Scc >/dev/null 2>&1 || true
    _success "${MSG[CACHE_ALL_DONE]}"
    return
  fi

  _info "${MSG[STEP_CACHE]}"
  if [[ "$DRY_RUN" == true ]]; then
    dry_run_action "$PKG_MNGR -Sc --noconfirm"
    _success "${MSG[DRY_STEP_DONE]}"
    return
  fi
  "$PKG_MNGR" -Sc --noconfirm >/dev/null 2>&1 || true
  _success "${MSG[CACHE_DONE]}"
}

cleanup_download_dirs() {
  local target_dir="/var/cache/pacman/pkg"
  if [[ ! -d "$target_dir" ]]; then
    return
  fi

  _info "${MSG[STEP_BROKEN]}"
  if [[ "$DRY_RUN" == true ]]; then
    local count
    count=$(sudo find "$target_dir" -maxdepth 1 -type d -name "download-*" 2>/dev/null | wc -l | xargs)
    dry_run_action "remove download-* directories under $target_dir (found: $count)"
    _success "${MSG[DRY_STEP_DONE]}"
    return
  fi
  sudo find "$target_dir" -maxdepth 1 -type d -name "download-*" -exec rm -rf {} + 2>/dev/null || true
  _success "${MSG[BROKEN_DONE]}"
}

cleanup_journal() {
  _info "${MSG[STEP_LOG]}"
  if [[ "$DRY_RUN" == true ]]; then
    dry_run_action "journalctl --vacuum-time=2weeks"
    _success "${MSG[DRY_STEP_DONE]}"
    return
  fi
  sudo journalctl --vacuum-time=2weeks >/dev/null 2>&1 || true
  _success "${MSG[LOG_DONE]}"
}

cleanup_coredump() {
  local coredump_dir="/var/lib/systemd/coredump"
  _info "${MSG[STEP_COREDUMP]}"

  if [[ ! -d "$coredump_dir" ]]; then
    _success "${MSG[COREDUMP_NONE]}"
    return
  fi

  if [[ "$DRY_RUN" == true ]]; then
    local count
    count=$(sudo find "$coredump_dir" -maxdepth 1 -type f 2>/dev/null | wc -l | xargs)
    dry_run_action "remove files in $coredump_dir (found: $count)"
    _success "${MSG[DRY_STEP_DONE]}"
    return
  fi

  sudo find "$coredump_dir" -mindepth 1 -delete 2>/dev/null || true
  _success "${MSG[COREDUMP_DONE]}"
}

cleanup_user_cache() {
  local trash_dir="$HOME/.local/share/Trash"
  local thumb_dir="$HOME/.cache/thumbnails"
  local clip_dir="$HOME/.cache/shorinclip"

  _info "${MSG[STEP_TRASH]}"

  if [[ "$DRY_RUN" == true ]]; then
    local trash_count thumb_count clip_count
    trash_count=$( [[ -d "$trash_dir" ]] && find "$trash_dir" -mindepth 1 2>/dev/null | wc -l | xargs || echo 0 )
    thumb_count=$( [[ -d "$thumb_dir" ]] && find "$thumb_dir" -type f -atime +30 2>/dev/null | wc -l | xargs || echo 0 )
    clip_count=$( [[ -d "$clip_dir" ]] && find "$clip_dir" -type f -atime +30 2>/dev/null | wc -l | xargs || echo 0 )
    dry_run_action "clear Trash entries (found: $trash_count)"
    dry_run_action "clear thumbnail files older than 30 days (found: $thumb_count)"
    dry_run_action "clear shorinclip files older than 30 days (found: $clip_count)"
    _success "${MSG[DRY_STEP_DONE]}"
    return
  fi

  [[ -d "$trash_dir" ]] && find "$trash_dir" -mindepth 1 -delete 2>/dev/null || true
  _success "${MSG[TRASH_DONE]}"

  [[ -d "$thumb_dir" ]] && find "$thumb_dir" -type f -atime +30 -delete 2>/dev/null || true
  _success "${MSG[THUMB_DONE]}"

  [[ -d "$clip_dir" ]] && find "$clip_dir" -type f -atime +30 -delete 2>/dev/null || true
  _success "${MSG[CLIP_DONE]}"
}

cleanup_flatpak() {
  if ! command -v flatpak >/dev/null 2>&1; then
    return
  fi

  _info "${MSG[STEP_FLATPAK]}"
  if [[ "$DRY_RUN" == true ]]; then
    dry_run_action "flatpak uninstall --unused -y"
    _success "${MSG[DRY_STEP_DONE]}"
    return
  fi
  flatpak uninstall --unused -y >/dev/null 2>&1 || true
  _success "${MSG[FLATPAK_DONE]}"
}

is_root_btrfs() {
  [[ "$(findmnt -n -o FSTYPE / 2>/dev/null)" == "btrfs" ]]
}

load_snapper_configs() {
  mapfile -t SNAPPER_CONFIGS < <(
    sudo LC_ALL=C snapper list-configs 2>/dev/null | awk -F'|' '
      NR > 2 {
        gsub(/^[ \t]+|[ \t]+$/, "", $1)
        if ($1 != "") print $1
      }
    '
  )
}

check_btrfs_cleanup_requirements() {
  _info "${MSG[STEP_BTRFS_CHECK]}"

  if ! is_root_btrfs; then
    _warn "${MSG[BTRFS_SKIP_NOT_BTRFS]}"
    return 1
  fi

  if ! command -v snapper >/dev/null 2>&1; then
    _warn "${MSG[BTRFS_SKIP_NO_SNAPPER]}"
    return 1
  fi

  load_snapper_configs
  if [[ ${#SNAPPER_CONFIGS[@]} -eq 0 ]]; then
    _warn "${MSG[BTRFS_SKIP_NO_CONFIG]}"
    return 1
  fi

  return 0
}

cleanup_snapshots_normal_mode() {
  _info "${MSG[STEP_SNAP]}"

  local conf
  for conf in "${SNAPPER_CONFIGS[@]}"; do
    if [[ "$DRY_RUN" == true ]]; then
      dry_run_action "snapper -c $conf cleanup number && snapper -c $conf cleanup timeline"
      printf "  ${H_CYAN}Auto-Cleanup Preview:${NC} [%-4s]\n" "$conf"
      continue
    fi
    sudo snapper -c "$conf" cleanup number >/dev/null 2>&1 || true
    sudo snapper -c "$conf" cleanup timeline >/dev/null 2>&1 || true
    printf "  ${H_CYAN}Auto-Cleanup Executed:${NC} [%-4s]\n" "$conf"
  done

  if [[ "$DRY_RUN" == true ]]; then
    if [[ $found_backups -eq 1 ]]; then
      _success "${MSG[DRY_STEP_DONE]}"
    else
      _success "${MSG[BTRFS_BA_NONE]}"
    fi
    return
  fi

  _success "${MSG[SNAP_DONE]}"
}

cleanup_snapshots_all_mode() {
  _info "${MSG[STEP_CLEAR_SNAP]}"

  local conf snap_id snap_desc
  for conf in "${SNAPPER_CONFIGS[@]}"; do
    while IFS='|' read -r snap_id _ _ _ _ _ snap_desc _; do
      snap_id=$(echo "$snap_id" | xargs)
      snap_desc=$(echo "$snap_desc" | xargs)

      [[ "$snap_id" =~ ^[0-9]+$ ]] || continue
      [[ "$snap_id" == "0" ]] && continue
      [[ "${snap_desc,,}" == before* ]] && continue

      if [[ "$DRY_RUN" == true ]]; then
        [[ -z "$snap_desc" ]] && snap_desc="N/A"
        printf "  ${H_CYAN}Would Remove Snapshot:${NC} [%-4s] ID: %-3s | Desc: %s\n" "$conf" "$snap_id" "$snap_desc"
        continue
      fi

      if sudo snapper -c "$conf" delete "$snap_id" >/dev/null 2>&1; then
        [[ -z "$snap_desc" ]] && snap_desc="N/A"
        printf "  ${H_CYAN}Removed Snapshot:${NC} [%-4s] ID: %-3s | Desc: %s\n" "$conf" "$snap_id" "$snap_desc"
      fi
    done < <(sudo LC_ALL=C snapper -c "$conf" list 2>/dev/null || true)
  done

  if [[ "$DRY_RUN" == true ]]; then
    _success "${MSG[DRY_STEP_DONE]}"
    return
  fi

  _success "${MSG[CLEAR_SNAP_DONE]}"
}

cleanup_btrfs_assistant_backups() {
  _info "${MSG[STEP_BTRFS_BA]}"

  if ! command -v btrfs >/dev/null 2>&1; then
    _warn "${MSG[BTRFS_TOOL_MISSING]}"
    return
  fi

  local btrfs_root_dev mount_dir found_backups=0
  btrfs_root_dev=$(findmnt -n -o SOURCE / | cut -d'[' -f1)
  mount_dir=$(mktemp -d /tmp/btrfs_clean_XXXX)

  if ! sudo mount -t btrfs -o subvolid=5 "$btrfs_root_dev" "$mount_dir" 2>/dev/null; then
    rmdir "$mount_dir" || true
    _warn "${MSG[BTRFS_MOUNT_FAIL]}"
    return
  fi

  while IFS= read -r -d '' subvol_dir; do
    if sudo btrfs subvolume show "$subvol_dir" >/dev/null 2>&1; then
      if [[ "$DRY_RUN" == true ]]; then
        printf "  ${H_CYAN}Would Remove Backup Subvol:${NC} %s\n" "$(basename "$subvol_dir")"
      else
        sudo btrfs subvolume delete "$subvol_dir" >/dev/null 2>&1 || true
        printf "  ${H_CYAN}Removed Backup Subvol:${NC} %s\n" "$(basename "$subvol_dir")"
      fi
      found_backups=1
    fi
  done < <(sudo find "$mount_dir" -maxdepth 1 -type d -name "*_backup_20*" -print0 2>/dev/null)

  sudo umount "$mount_dir" || true
  rmdir "$mount_dir" || true

  if [[ "$DRY_RUN" == true ]]; then
    _success "${MSG[DRY_STEP_DONE]}"
    return
  fi

  if [[ $found_backups -eq 1 ]]; then
    _success "${MSG[BTRFS_BA_DONE]}"
  else
    _success "${MSG[BTRFS_BA_NONE]}"
  fi
}

cleanup_btrfs_related() {
  if ! check_btrfs_cleanup_requirements; then
    return
  fi

  if [[ "$CLEAN_ALL" == true ]]; then
    cleanup_snapshots_all_mode
  else
    cleanup_snapshots_normal_mode
  fi

  cleanup_btrfs_assistant_backups
}

main() {
  parse_args "$@"
  setup_messages
  detect_package_manager
  print_intro_and_confirm

  _info "${MSG[HELPER_USE]}" "$PKG_MNGR"
  start_sudo_keepalive

  cleanup_orphans
  cleanup_package_cache
  cleanup_download_dirs
  cleanup_journal
  cleanup_coredump
  cleanup_user_cache
  cleanup_flatpak
  cleanup_btrfs_related

  printf "\n"
  _success "${MSG[DONE]}"
}

main "$@"
