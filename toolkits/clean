#!/bin/bash
# Description: 系统与环境清理脚本

# 【功能说明】
# 1. 移除孤儿软件包 (Orphans)
# 2. 清理软件包缓存 (默认保留安装包，all 模式下完全清空)
# 3. 清理残留下载目录 (download-*)
# 4. 清理 systemd 日志 (只保留最近 2 周)
# 5. 清理 systemd-coredump
# 6. 清空用户回收站、缩略图与剪贴板缓存
# 7. 移除未使用的 Flatpak 运行时
# 8. 清理旧 Btrfs 快照与 btrfs-assistant 冗余备份子卷
#    (仅在「根分区是 btrfs 且 snapper 可用」时执行；all 模式保留 before 节点)

set -euo pipefail

SKIP_CONFIRM=false
CLEAN_ALL=false
DRY_RUN=false
PKG_MNGR=""
SUDO_PID=""
declare -a SNAPPER_CONFIGS=()

if [[ "${LC_MESSAGES:-${LANG:-}}" == *zh_CN* ]]; then
  UI_LANG="zh"
else
  UI_LANG="en"
fi

usage() {
  cat <<EOF
Usage: $(basename "$0") [options]

Options:
  --ui-lang zh|en    Force UI language (default: auto)
  all, --all         Enable aggressive cleanup (clear all cache & snapshots)
  --dry-run          Preview actions without making changes
  --yes, -y          Skip confirmation prompt (non-interactive)
  --help, -h         Show this help and exit
EOF
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --ui-lang)
      if [[ "${2:-}" =~ ^(zh|en)$ ]]; then
        UI_LANG="$2"
        shift 2
      else
        echo "Error: --ui-lang requires zh or en."
        exit 1
      fi
      ;;
    all | --all)
      CLEAN_ALL=true
      shift
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --yes | -y)
      SKIP_CONFIRM=true
      shift
      ;;
    --help | -h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      usage
      exit 1
      ;;
    esac
  done
}

